{
  "name": "skillshare-player-control",
  "version": "2.1.11",
  "type": "module",
  "description": "Basic keyboard controls for the Skillshare player.",
  "author": "Avi <avi6106@gmail.com>",
  "repository": "https://github.com/avi12/skillshare-player-control",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/avi12/skillshare-player-control",
  "scripts": {
    "dev": "wxt",
    "dev:rtl": "set VITE_LANG=he && wxt",
    "dev:firefox": "pnpm dev -b firefox --mv3",
    "dev:edge": "pnpm dev -b edge",
    "dev:opera": "pnpm dev -b opera",
    "build": "wxt build",
    "build:opera": "pnpm build -b opera",
    "build:firefox": "pnpm build -b firefox --mv3",
    "package": "wxt zip",
    "package:opera": "pnpm package -b opera",
    "package:firefox": "pnpm package -b firefox --mv3",
    "build:package": "pnpm build && pnpm package",
    "build:package:opera": "pnpm build:opera && pnpm package:opera",
    "build:package:firefox": "pnpm build:firefox && pnpm package:firefox",
    "build:package:all": "concurrently \"pnpm build:package\" \"pnpm build:package:opera\" \"pnpm build:package:firefox\" --names Chromium,Opera,Firefox",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.37",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.2",
    "eslint-config-avi12": "github:avi12/eslint-config-avi12",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.3.0",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.8.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "wxt": "^0.20.18"
  },
  "packageManager": "pnpm@10.30.3"
}
